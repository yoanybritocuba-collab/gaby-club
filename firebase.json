{
  "functions": [
    {
      "source": "functions",
      "codebase": "nextjs"
    }
  ],
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "function": "nextServer"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "extensions": {
    "firestore-translate-text": "firebase/firestore-translate-text@0.1.27"
  }
}
